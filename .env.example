# orchard-viper-forum-worker environment.
#
# Copy to .env (gitignored) and fill in. Restart the container after
# changing values — env_file is read at container creation, not on
# `docker compose restart`.

# ─── Hub binding ──────────────────────────────────────────────────────

# The clawborrator hub this agent registers with.
CLAWBORRATOR_HUB=https://next.clawborrator.com

# Channel token minted by `claw token mint --name orchard-viper-forum`.
# This is what authenticates the agent's MCP register on /channel.
CLAWBORRATOR_PAT=ck_live_...

# ─── Agent code ───────────────────────────────────────────────────────

# Git repo holding CLAUDE.md + specialists/viperclub.js. Cloned at
# container start; changes there propagate on the next restart.
REPO_URL=https://github.com/clawborrator/orchard-viper-forum-repo
REPO_BRANCH=main

# Routing name the agent registers with on the hub (without the @).
ROUTING_NAME=orchard-viper-forum

# ─── Forum wrapper config ─────────────────────────────────────────────

# Override the wrapper defaults if you need to. All optional; the
# defaults at the top of specialists/viperclub.js are sensible.
# VIPER_COOKIES_PATH=/secrets/viperclub.cookies.json
# VIPER_BASE_URL=https://www.viperclub.org/vca
# VIPER_DELAY_MS=1500
# VIPER_USER_AGENT=clawborrator-orchard-viper-forum/0.1 (+https://next.clawborrator.com)
