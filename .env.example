# orchard-viper-forum-worker environment.
#
# Copy to .env (gitignored) and fill in. Restart the container after
# changing values — env_file is read at container creation, not on
# `docker compose restart`. Use `docker compose up -d viper-forum`
# instead.
#
# Same env shape as worker_v1-example-reddit-engager-worker. The
# worker_v1 entrypoint reads these and writes /workspace/repo/.mcp.json
# at boot — you do NOT ship an .mcp.json in the repo itself.

# ─── Claude Code auth ──────────────────────────────────────────────────
# Pick ONE of these. The Anthropic API key is the simplest; the OAuth
# token works if you signed in via `claude` and want subscription
# billing instead of API spend.

ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_ACCESS_TOKEN=

# Model to run. `sonnet` is the sweet spot for an agent that does
# forum reading + JSON parsing + citation composition. `haiku` works
# if you want it cheaper; `opus` is overkill for this workload.
MODEL=sonnet

# ─── clawborrator hub binding ──────────────────────────────────────────

# Channel token minted via `claw token mint --name orchard-viper-forum`.
# The worker entrypoint writes this into /workspace/repo/.mcp.json so
# the clawborrator-mcp server inside Claude Code authenticates the
# /channel WS register. Without this the agent never appears in the
# session list.
CLAWBORRATOR_TOKEN=

# Hub WebSocket URL. wss:// for next.clawborrator.com; ws:// for a
# localhost dev hub.
CLAWBORRATOR_HUB_URL=wss://next.clawborrator.com

# Routing name the agent registers with. Becomes @orchard-viper-forum
# in the dashboard. Match the published agent handle's slug.
CLAWBORRATOR_ROUTING_NAME=orchard-viper-forum

# ─── Agent code ────────────────────────────────────────────────────────

# Git repo holding CLAUDE.md + specialists/viperclub.js. Cloned at
# container start; changes there propagate on the next restart.
REPO_URL=https://github.com/clawborrator/orchard-viper-forum-repo
REPO_REF=main
REPO_DIR_NAME=repo

# Optional: PAT if REPO_URL is private. orchard-viper-forum-repo is
# public so this stays empty.
REPO_PAT=
REPO_PAT_USER=x-access-token

# Git identity for any commits the agent makes inside the cloned repo
# (e.g. selector patches, screenshot audits). Optional.
GIT_USER_EMAIL=
GIT_USER_NAME=

# ─── Agent boot ────────────────────────────────────────────────────────

# The initial prompt the entrypoint feeds Claude Code on first run.
# Tells the agent to read its playbook and verify the forum session.
CLAUDE_INITIAL_PROMPT=Read /workspace/repo/CLAUDE.md carefully — that is your playbook. Then run `node specialists/viperclub.js auth-check` to verify the VCA forum cookies are still alive. Once confirmed, idle and wait for inbound dispatches via route_to_peer.

# Pass --dangerously-skip-permissions to Claude Code. Required for
# autonomous workers since every bash + tool call would otherwise
# prompt and block.
CLAUDE_SKIP_PERMISSIONS=1

# Set to 1 to disable the worker's auto-Enter loop. Default 0 (enabled)
# is correct for unattended containers.
DISABLE_AUTOENTER=0

# ─── Forum wrapper config (optional overrides) ─────────────────────────

# All optional; the defaults at the top of specialists/viperclub.js are
# sensible. Uncomment only when you need to deviate.
# VIPER_COOKIES_PATH=/secrets/viperclub.cookies.json
# VIPER_BASE_URL=https://www.viperclub.org/vca
# VIPER_DELAY_MS=1500
# VIPER_USER_AGENT=clawborrator-orchard-viper-forum/0.1 (+https://next.clawborrator.com)
